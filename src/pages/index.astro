---
import AboutSection from "../components/AboutSection.astro";
import ApplicationsSection from "../components/ApplicationsSection.astro";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ProductSection from "../components/ProductSection.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <meta
      name="description"
      content="BEST Machine provides horizontal injection molding machines, plastic machinery, mold coordination and production solutions for packaging, daily goods, medical, logistics and construction applications."
    />
    <title>BEST Machine | Horizontal Injection Molding Machines</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-shell">
      <Header currentPage="/" />
      <main id="top">
        <Hero />
        <ProductSection />
        <ApplicationsSection />
        <AboutSection />
        <ContactSection />
      </main>
      <Footer />
    </div>
  </body>
</html>
