---
import { CircleAlert, House } from "@lucide/astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page Not Found | BEST Machine</title>
  </head>
  <body>
    <main class="min-h-screen w-full flex items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100">
      <div class="w-full max-w-lg mx-4 shadow-lg border-0 bg-white/80 backdrop-blur-sm rounded-lg p-8 text-center">
        <div class="flex justify-center mb-6">
          <CircleAlert class="h-16 w-16 text-red-500" />
        </div>
        <h1 class="text-4xl font-bold text-slate-900 mb-2">404</h1>
        <h2 class="text-xl font-semibold text-slate-700 mb-4">Page Not Found</h2>
        <p class="text-slate-600 mb-8 leading-relaxed">
          Sorry, the page you are looking for doesn't exist.<br />
          It may have been moved or deleted.
        </p>
        <a
          href="/"
          class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg transition-all duration-200 shadow-md hover:shadow-lg inline-flex items-center justify-center gap-2"
        >
          <House class="w-4 h-4" />
          Go Home
        </a>
      </div>
    </main>
  </body>
</html>
