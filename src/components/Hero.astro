---
import { ArrowRight, Sparkles } from "@lucide/astro";

const heroImage =
  "https://d2xsxph8kpxj0f.cloudfront.net/310519663387716019/V4ZdDXX97fYCoS4pbyWrL4/bestmachines_hero_injection_machine-hn9n5jCkLBtnYpwbgFNmc7.webp";

const metrics = [
  { value: "19+", label: "Years in plastics machinery" },
  { value: "30M+", label: "RMB fixed assets" },
  { value: "20", label: "Professional designers" },
  { value: "100+", label: "Production team members" },
];
---

<section class="hero-section">
  <div class="hero-content">
    <div class="hero-copy">
      <span class="hero-eyebrow">One-stop plastics machinery and mold solutions</span>
      <h1>Horizontal Injection Molding Machines for Stable Production</h1>
      <p>
        BEST Machine develops and manufactures plastic machinery, molds and supporting services for
        packaging, daily goods, medical consumables, industrial logistics and construction material
        applications.
      </p>
      <div class="hero-actions">
        <a
          class="primary-link"
          href="/contact#inquiry-form"
        >
          Discuss Your Project <ArrowRight class="h-5 w-5" />
        </a>
        <a class="secondary-link" href="#product">View Machine Capability</a>
      </div>
    </div>
    <div class="hero-visual">
      <img
        src={heroImage}
        alt="BEST horizontal injection molding machine in an industrial production environment"
      />
      <div class="hero-badge">
        <Sparkles class="h-5 w-5" />
        <span>Stable molding · Mold coordination · Service support</span>
      </div>
    </div>
  </div>
</section>

<section class="metrics-strip" aria-label="Company highlights">
  {
    metrics.map((metric) => (
      <div class="metric-item">
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
      </div>
    ))
  }
</section>
